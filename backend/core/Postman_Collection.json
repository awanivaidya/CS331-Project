{
  "info": {
    "name": "Customer Communication API with NLP & Risk Analysis",
    "description": "AI-Based Customer Communication Analysis and Risk Alert System - Complete API Collection with NLP Processing and Risk Alerts",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "customerId", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "domainId", "value": "" },
    { "key": "slaId", "value": "" },
    { "key": "communicationId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Check server and MongoDB connection status. Expect: {\"status\":\"ok\",\"mongodb\":\"connected\"}"
          }
        },
        {
          "name": "Root endpoint (API list)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/",
            "description": "List all available API endpoints"
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List customers",
          "request": { 
            "method": "GET", 
            "url": "{{baseUrl}}/api/customers",
            "description": "Get all customers with their sentiment scores and risk status"
          }
        },
        {
          "name": "Create customer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/customers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation\",\n  \"priority\": \"high\"\n}"
            },
            "description": "Create a new customer. Copy _id from response into collection variable 'customerId'. Customer starts with sentimentScore: 0, riskStatus: null"
          }
        },
        {
          "name": "Get customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/customers/{{customerId}}",
            "description": "Get customer details including sentimentScore, riskStatus, and sentimentHistory"
          }
        },
        {
          "name": "Update customer",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/customers/{{customerId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation Updated\",\n  \"priority\": \"critical\"\n}"
            },
            "description": "Update customer details. Note: sentimentScore and riskStatus are auto-calculated from communications"
          }
        },
        {
          "name": "Delete customer",
          "request": { 
            "method": "DELETE", 
            "url": "{{baseUrl}}/api/customers/{{customerId}}",
            "description": "Delete a customer"
          }
        }
      ]
    },
    {
      "name": "SLAs",
      "item": [
        {
          "name": "List SLAs",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/slas" }
        },
        {
          "name": "List SLAs by customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/slas?customerId={{customerId}}"
          }
        },
        {
          "name": "Create SLA",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/slas",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"responseTime\": 24,\n  \"deadline\": \"2026-03-01\",\n  \"riskThreshold\": 0.7,\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "description": "Set customerId in collection variables first."
          }
        },
        {
          "name": "Get SLA",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/slas/{{slaId}}" }
        },
        {
          "name": "Update SLA",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/slas/{{slaId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"responseTime\": 48\n}" }
          }
        },
        {
          "name": "Delete SLA",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/slas/{{slaId}}" }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List projects",
          "request": { 
            "method": "GET", 
            "url": "{{baseUrl}}/api/projects",
            "description": "Get all projects. Projects now include 'tasks' array with actionable items from NLP"
          }
        },
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/projects",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"E-commerce Platform Migration\",\n  \"status\": \"active\",\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "description": "Create a new project. Copy _id from response into collection variable 'projectId'. Tasks array starts empty, gets populated when communications are analyzed."
          }
        },
        {
          "name": "Get project",
          "request": { 
            "method": "GET", 
            "url": "{{baseUrl}}/api/projects/{{projectId}}",
            "description": "Get project details including tasks array with actionable items extracted from latest communication"
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/projects/{{projectId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\"\n}" }
          }
        },
        {
          "name": "Delete project",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/projects/{{projectId}}" }
        }
      ]
    },
    {
      "name": "Domains",
      "item": [
        {
          "name": "List domains",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/domains" }
        },
        {
          "name": "Create domain",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/domains",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Technical Support\"\n}" },
            "description": "Copy _id from response into collection variable domainId"
          }
        },
        {
          "name": "Get domain",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/domains/{{domainId}}" }
        },
        {
          "name": "Update domain",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/domains/{{domainId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Technical Support & Billing\"\n}" }
          }
        },
        {
          "name": "Delete domain",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/domains/{{domainId}}" }
        }
      ]
    },
    {
      "name": "Communications (with NLP)",
      "item": [
        {
          "name": "List communications",
          "request": { 
            "method": "GET", 
            "url": "{{baseUrl}}/api/communications",
            "description": "Get all communications. Each has sentiment score and summary from NLP analysis"
          }
        },
        {
          "name": "List by project",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/communications?projectId={{projectId}}"
          }
        },
        {
          "name": "List by type (email)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/communications?type=email"
          }
        },
        {
          "name": "Upload email (NEGATIVE - triggers alert)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/communications/email",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"We are extremely disappointed with the recent delays in the project. The system must provide daily status updates and all critical bugs should be resolved within 4 hours. This is urgent and requires immediate attention. Please escalate any blockers to management immediately.\",\n  \"subject\": \"URGENT: Project Delays and Critical Issues\",\n  \"sender\": \"john.doe@acme.com\",\n  \"projectId\": \"{{projectId}}\",\n  \"domainId\": \"{{domainId}}\",\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "description": "⚠️ NLP INTEGRATION: Analyzes email content, extracts tasks, calculates sentiment, updates customer risk. Response includes: communication, nlpAnalysis (sentimentScore, staffTasks), and alert (if critical). Project tasks are auto-updated. Customer sentiment is tracked and risk status calculated."
          }
        },
        {
          "name": "Upload email (POSITIVE - improves sentiment)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/communications/email",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Thank you for the excellent work on the recent sprint. We are very pleased with the progress and the team's responsiveness. The deliverables exceeded our expectations. Please continue with the current approach and maintain the quality of work.\",\n  \"subject\": \"Great Progress - Thank You!\",\n  \"sender\": \"john.doe@acme.com\",\n  \"projectId\": \"{{projectId}}\",\n  \"domainId\": \"{{domainId}}\",\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "description": "Positive sentiment email. Shows how customer sentiment score improves (weighted average) and risk status may change from critical → warning → stable"
          }
        },
        {
          "name": "Upload email (NEUTRAL)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/communications/email",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"We are facing some delays with the deployment. Please confirm the new timeline and provide a status update by end of week.\",\n  \"subject\": \"Timeline confirmation needed\",\n  \"sender\": \"client@acme.com\",\n  \"projectId\": \"{{projectId}}\",\n  \"domainId\": \"{{domainId}}\",\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "description": "Neutral sentiment example"
          }
        },
        {
          "name": "Upload transcript (with NLP)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/communications/transcript",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Meeting discussion about project timeline. Customer expressed concerns about deployment schedule. They need weekly status reports and expect 24-hour response time for priority 1 issues. Action items: implement automated testing and improve documentation.\",\n  \"meetingDate\": \"2026-02-17\",\n  \"participants\": [\"john.doe@acme.com\", \"manager@company.com\", \"tech.lead@company.com\"],\n  \"projectId\": \"{{projectId}}\",\n  \"domainId\": \"{{domainId}}\",\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "description": "Same NLP processing as emails. Analyzes meeting transcript, extracts action items, updates project tasks, calculates sentiment and risk."
          }
        },
        {
          "name": "Get communication",
          "request": { 
            "method": "GET", 
            "url": "{{baseUrl}}/api/communications/{{communicationId}}",
            "description": "View communication with sentiment score and summary"
          }
        },
        {
          "name": "Re-analyze existing communication",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/communications/{{communicationId}}/analyze",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "🆕 NEW ENDPOINT: Re-run NLP analysis on an existing communication. Useful for testing or if NLP failed initially. Updates sentiment, tasks, and customer risk."
          }
        },
        {
          "name": "Update communication",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/communications/{{communicationId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Updated subject line\"\n}"
            },
            "description": "Manually update communication fields (not recommended - NLP auto-populates sentiment/summary)"
          }
        },
        {
          "name": "Delete communication",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/communications/{{communicationId}}" }
        }
      ]
    },
    {
      "name": "Alerts & Risk Dashboard",
      "item": [
        {
          "name": "Risk Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/alerts/dashboard",
            "description": "🆕 NEW ENDPOINT: Get complete risk overview. Shows: totalCustomers, criticalCount, warningCount, stableCount, active alerts, and all customers with their risk status. Risk Thresholds: stable (>-0.30), warning (-0.60 to -0.30), critical (≤-0.60)"
          }
        },
        {
          "name": "Critical Alerts Only",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/alerts/critical",
            "description": "🆕 NEW ENDPOINT: Get only customers with CRITICAL risk status (sentiment ≤ -0.60). Shows all projects for critical customers with detailed alert messages."
          }
        }
      ]
    }
  ]
}